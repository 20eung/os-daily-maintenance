# ─────────────────────────────────────────────────────────
# Linux (Ubuntu/Debian) 전용 설정 (.env.linux.sample)
# .env 이후 로드되며,同名 설정을 덮어씁니다.
# 복사 후 .env.linux로 이름 변경하여 사용
# ─────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────
# 프로젝트 디렉토리 설정
# ─────────────────────────────────────────────────────────
# 프로젝트들이 모여 있는 상위 디렉토리
USER_PROJECT_DIR="/home/YOUR_USERNAME/PROJECT_ROOT"

# 여러 프로젝트 상위 디렉토리 (공백으로 구분)
USER_PROJECT_DIRS="/home/YOUR_USERNAME/PROJECT_ROOT /data/projects"

# Git 저장소 동기화 루트 (하위 .git 자동 탐색, 깊이 3)
GIT_SYNC_ROOT="/home/YOUR_USERNAME/PROJECT_ROOT"

# ─────────────────────────────────────────────────────────
# 로그 관리
# ─────────────────────────────────────────────────────────
# 프로젝트 로그 정리를 원하는 추가 디렉토리 (공백으로 구분)
# CLEANUP_LOG_DIRS="/var/log/nginx /var/log/redis"

# ─────────────────────────────────────────────────────────
# 패키지 관리
# ─────────────────────────────────────────────────────────
# pip 업데이트 대상 패키지 (공백으로 구분)
# 예: PIP_TARGET_PACKAGES="boto3 requests urllib3 certifi anthropic pandas websockets"
PIP_TARGET_PACKAGES="boto3 requests urllib3 certifi anthropic pandas websockets"

# Docker pull 대상 이미지 (공백으로 구분)
# DOCKER_TARGET_IMAGES="nginx:alpine redis:alpine mysql:8.0"
DOCKER_TARGET_IMAGES="nginx:alpine"

# ─────────────────────────────────────────────────────────
# 시스템 모니터링 임계값
# ─────────────────────────────────────────────────────────
# 디스크 사용률 경고 (%) - 80~90 권장
DISK_USAGE_THRESHOLD=85

# 메모리 사용률 경고 (%)
MEMORY_USAGE_THRESHOLD=85

# CPU 온도 경고 (°C)
CPU_TEMP_THRESHOLD=80

# 디스크 온도 경고 (°C)
DISK_TEMP_THRESHOLD=55

# ─────────────────────────────────────────────────────────
# Docker / Docker Compose
# ─────────────────────────────────────────────────────────
# Docker Compose 프로젝트 검색 디렉토리 (USER_PROJECT_DIRS와 공유)
# Docker가 설치되어 있어야 함
