# ─────────────────────────────────────────────────────────
# .gitignore
# ─────────────────────────────────────────────────────────

# 모든 환경 설정 파일 무시 (보안)
.env*

# 단, 가이드 샘플 파일들은 제외 (GitHub에 업로드)
!.env.sample
!.env.darwin.sample
!.env.linux.sample

# 로그 파일 제외
/logs/
*.log

# 기타 임시 파일
.DS_Store
/tmp/
.bkit/
.claude/
