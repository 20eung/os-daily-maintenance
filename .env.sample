# ─────────────────────────────────────────────────────────
# 공통 환경 설정 (.env.sample)
# 모든 OS 공통 설정 - 복사 후 .env로 이름 변경하여 사용
# ─────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────
# Telegram 알림 설정
# ─────────────────────────────────────────────────────────
# Telegram Bot API Key (필수)
MAINTENANCE_BOT_KEY="YOUR_BOT_TOKEN_HERE"

# 수신할 채팅방/사용자 ID (필수)
MAINTENANCE_CHAT_ID="YOUR_CHAT_ID_HERE"

# ─────────────────────────────────────────────────────────
# 기본 경로 설정
# ─────────────────────────────────────────────────────────
# 유지보수 실행 시 사용할 홈 디렉토리 (기본값: 현재 $HOME)
# MAINTENANCE_HOME="/home/YOUR_USERNAME"

# 시스템 PATH에 추가할 디렉토리 (기본값 포함됨)
# MAINTENANCE_PATH="/home/YOUR_USERNAME/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# ─────────────────────────────────────────────────────────
# 로그 설정
# ─────────────────────────────────────────────────────────
# 로그 파일 저장 경로 (기본값: $HOME/os-daily-maintenance/logs)
# LOG_STAGING_DIR="/var/log/maintenance"

# 로그 파일 보관 기간 (일)
LOG_RETENTION_DAYS=30
