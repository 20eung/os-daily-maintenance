# ─────────────────────────────────────────────────────────
# System & User Settings
# ─────────────────────────────────────────────────────────
# 사용자의 홈 디렉토리 절대 경로 (예: /Users/username 또는 /home/username)
MAINTENANCE_HOME="/Users/YOUR_USERNAME"

# 실행 시 필요한 바이너리 경로 (기본값 외 추가가 필요한 경우)
MAINTENANCE_PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

# conda 설정을 위한 conda.sh 파일 경로 (Conda 사용 시)
MAINTENANCE_CONDA_SH="/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh"

# ─────────────────────────────────────────────────────────
# Telegram Notification Settings
# ─────────────────────────────────────────────────────────
MAINTENANCE_BOT_KEY="YOUR_TELEGRAM_BOT_TOKEN"
MAINTENANCE_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"

# ─────────────────────────────────────────────────────────
# Directories & Paths
# ─────────────────────────────────────────────────────────
# Git 저장소를 탐색할 루트 경로
USER_PROJECT_DIR="${MAINTENANCE_HOME}/Project"

# 로그파일이 저장될 경로
LOG_STAGING_DIR="${USER_PROJECT_DIR}/Daily-Maintenance/logs"

# 30일이 지난 로그를 정리할 추가 디렉토리 (공백으로 구분)
CLEANUP_LOG_DIRS="${MAINTENANCE_HOME}/.logs/app1 ${MAINTENANCE_HOME}/.logs/app2"

# ─────────────────────────────────────────────────────────
# Packages & Docker Images
# ─────────────────────────────────────────────────────────
# 업데이트할 pip 패키지 목록 (공백으로 구분)
PIP_TARGET_PACKAGES="boto3 botocore requests urllib3 certifi anthropic tavily-python pycryptodome pandas websockets"

# 업데이트 체크할 주요 Docker 이미지 목록 (공백으로 구분)
DOCKER_TARGET_IMAGES="nginx:alpine portainer/portainer-ce:latest portainer/agent:latest lipanski/docker-static-website:latest"
