# ─────────────────────────────────────────────────────────
# System & User Settings (자동 감지 권장)
# ─────────────────────────────────────────────────────────
# 사용자의 홈 디렉토리 절대 경로
# 주석 처리 시 자동으로 현재 $HOME 사용
# MAINTENANCE_HOME="/home/ubuntu"

# 실행 시 필요한 바이너리 경로 (선택사항)
# 주석 처리 시 시스템 기본 PATH 사용
# MAINTENANCE_PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# ─────────────────────────────────────────────────────────
# Telegram Notification Settings (선택사항)
# ─────────────────────────────────────────────────────────
# 토큰을 다른 곳에 저장하거나 환경 변수로 설정 권장
# MAINTENANCE_BOT_KEY="YOUR_TELEGRAM_BOT_TOKEN"
# MAINTENANCE_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"

# ─────────────────────────────────────────────────────────
# Directories & Paths
# ─────────────────────────────────────────────────────────
# 프로젝트 루트 디렉토리 (docker-compose.yml, git 저장소 탐색 경로)
# 기본값: /data (다른 경로는 여기서 설정)
USER_PROJECT_DIR="/data"

# 로그파일이 저장될 경로 (자동: $HOME/os-daily-maintenance/logs)
# 주석 처리 시 기본 경로 사용
# LOG_STAGING_DIR="/custom/log/path"

# 30일이 지난 로그를 정리할 추가 디렉토리 (공백으로 구분, 선택사항)
# CLEANUP_LOG_DIRS="/var/log/myapp /var/log/otherapp"

# ─────────────────────────────────────────────────────────
# System Monitoring Thresholds (임계값 설정, 선택사항)
# ─────────────────────────────────────────────────────────
# 디스크 사용률 경고 임계값 (기본값: 85%)
# DISK_USAGE_THRESHOLD=85

# 메모리 사용률 경고 임계값 (기본값: 85%)
# MEMORY_USAGE_THRESHOLD=85

# CPU 온도 경고 임계값 (기본값: 80°C, lm-sensors 필요)
# CPU_TEMP_THRESHOLD=80

# 디스크 온도 경고 임계값 (기본값: 55°C, smartctl 필요)
# DISK_TEMP_THRESHOLD=55

# ─────────────────────────────────────────────────────────
# 자동 감지 설정 (범용성 우선)
# ─────────────────────────────────────────────────────────
# ✅ pip: 설치된 모든 패키지 자동 감지 및 업데이트
# ✅ Docker Compose: USER_PROJECT_DIR 아래의 모든 docker-compose.yml 자동 발견
# ✅ Git 저장소: USER_PROJECT_DIR 아래의 모든 .git 자동 발견
# ✅ systemd 서비스: 실패한 서비스 자동 감지
# ✅ 네트워크: 인터넷 연결 상태 자동 확인
# ✅ 커널: 재부팅 필요 여부 자동 감지
# ✅ 보안 업데이트: 보안 패치 자동 감지
# ✅ 파일시스템: 주간 fsck 자동 스케줄
# ✅ 온도 감시: CPU/디스크 온도 자동 감지 (선택사항)
# 수동 지정 불필요
